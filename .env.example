# ── APP ────────────────────────────────────────────
APP_NAME=Agentic Ticket System
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-prod-min-32-chars
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ── DATABASE ────────────────────────────────────────
POSTGRES_USER=ticket_user
POSTGRES_PASSWORD=ticket_pass
POSTGRES_DB=ticket_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ticket_user:ticket_pass@postgres:5432/ticket_db
DATABASE_SYNC_URL=postgresql://ticket_user:ticket_pass@postgres:5432/ticket_db

# ── REDIS ───────────────────────────────────────────
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@redis:6379/0
CELERY_BROKER_URL=redis://:redis_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_pass@redis:6379/2

# ── QDRANT ──────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant_secret
QDRANT_COLLECTION_TICKETS=tickets
QDRANT_COLLECTION_KB=knowledge_base

# ── MINIO ───────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_pass_123
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_BUCKET_ATTACHMENTS=ticket-attachments
MINIO_BUCKET_MODELS=ml-models

# ── OPENAI ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_ADVANCED=gpt-4o
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.2
OPENAI_REQUEST_TIMEOUT=60

# ── EMBEDDINGS (local BGE - no API cost) ────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ── JWT ─────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MONITORING ──────────────────────────────────────
GRAFANA_PASSWORD=grafana_pass
FLOWER_USER=admin
FLOWER_PASSWORD=flower_pass

# ── EMAIL ───────────────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=smtp_password
